<style>
  .navbar {
    padding: 10px 20px;
    z-index: 1000;
    backdrop-filter: blur(10px);
    background-color: rgba(255, 255, 255, 0.9) !important;
  }

  .nav-left,
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-center {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .navbar-brand i {
    font-size: 1.5rem;
    color: #ff385c;
  }

  .nav-link {
    font-weight: 500;
    transition: 0.2s ease;
    color: #333;
  }

  .nav-link:hover {
    color: #ff385c !important;
  }

  .search-form {
    display: flex;
    align-items: center;
    max-width: 450px;
    width: 100%;
  }

  .search-inp {
    border-radius: 25px 0 0 25px;
    padding: 8px 16px;
    border: 1px solid #ddd;
    border-right: none;
    font-size: 0.95rem;
    width: 100%;
    transition: 0.2s ease;
  }

  .search-inp:focus {
    outline: none;
    border-color: #ff385c;
    box-shadow: 0 0 0 2px rgba(255, 56, 92, 0.2);
  }

  .search-btn {
    border-radius: 0 25px 25px 0;
    background-color: #ff385c;
    color: white;
    border: none;
    padding: 8px 18px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: 0.2s ease;
  }

  .search-btn:hover {
    background-color: #e03150;
  }

  @media (max-width: 992px) {
    .nav-center {
      width: 100%;
      margin-top: 10px;
    }

    .search-form {
      width: 100%;
      margin: 10px 0
    }

    .nav-right {
      flex-direction: column;
      align-items: flex-start;
      margin-top: 10px;
    }

    .navbar-collapse {
      background: white;
      padding: 10px;
      border-radius: 10px;
      margin-top: 10px;
    }

    .nav-left {
      margin-bottom: 10px;
    }
  }

  .navbar-toggler {
    border: none;
  }

  .navbar-toggler:focus {
    box-shadow: none;
  }
</style>
<nav class="navbar navbar-expand-lg navbar-light bg-body-light border-bottom sticky-top">

  <div class="container-fluid">

    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <form class="d-flex search-form mx-auto" action="/listings" method="GET">
        <input class="form-control search-inp" type="search" name="search" placeholder="Search destinations">
        <button class="btn search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </form>

      <ul class="navbar-nav ms-auto">

        <% if(!currUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/signup">Sign up</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/login">Log in</a>
          </li>
          <% } %>

            <% if(currUser) { %>
              <li class="nav-item">
                <a class="nav-link" href="/logout">Log out</a>
              </li>
              <% } %>

                <% if(currUser && currUser.role==="owner" ) { %>
                  <li class="nav-item">
                    <a class="nav-link" href="/listings/new">Add Listing</a>
                  </li>
                  <% } %>

      </ul>

    </div>

  </div>
</nav>